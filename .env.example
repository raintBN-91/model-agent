# MoFix Backend — 环境变量配置

# LLM 配置（Anthropic Claude）
# 未配置时自动读取 ~/.claude/settings.json 中的 env 配置
ANTHROPIC_AUTH_TOKEN=sk-ant-api03-xxx
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# 工作流规划专用模型（为空则复用 ANTHROPIC_MODEL）
# WORKFLOW_LLM_MODEL=claude-3-haiku-20240307

# MCP 服务器配置
# MCP_SERVERS 在 config.py 中已有默认值，一般无需修改

# Hermes 自演进引擎
HERMES_ENABLED=true
# HERMES_DATA_DIR=
# HERMES_MEMORY_CAPACITY=500
# HERMES_SKILL_CAPACITY=50
# HERMES_INSIGHT_CAPACITY=200
