// ============================================================================
// Ascend C Kernel 直调样例 - Add 算子
// ============================================================================
// 
// [MODIFY] 创建新算子时的修改点（搜索 [MODIFY] 标记）:
// 1. 类名: KernelAdd → Kernel<YourOp>
// 2. Kernel函数名: add_custom → <your_op>_custom
// 3. Tiling结构体: AddTilingData → <YourOp>TilingData
// 4. 计算逻辑: AscendC::Add → 你的算子逻辑
// 5. 输入/输出数量: 根据你的算子调整
// 6. CMakeLists.txt: 目标名和源文件名
// 7. gen_data.py: 输入数据和 golden 计算
// 8. verify_result.py: dtype 和容差参数
// ============================================================================

#include <cstdint>
#include <iostream>
#include <vector>
#include "acl/acl.h"
#include "kernel_operator.h"
#include "data_utils.h"

// [CONFIG] 单次搬运/处理的数据量（元素数），影响 UB 内存占用
// 常用值: float32 用 4096/8192，float16 用 8192/16384
// 搬运时 256字节倍数时带宽利用率100%
constexpr uint32_t TILE_LENGTH = 4096;
constexpr uint32_t DOUBLE_BUFFER = 2;

// [MODIFY] Tiling 数据结构 - 向核函数传递的运行时参数
// 根据你的算子需求添加字段
struct AddTilingData {
    uint32_t blockNum;         // 需要使用的核数
    uint64_t totalLength;      // 总数据量（元素数）
    uint64_t numPerCore;       // 每 core 处理的元素个数
    uint64_t tailNumLastCore;  // 最后1个尾核处理的数据量（元素数）
};

// [MODIFY] Kernel 类 - 封装 NPU 上的计算逻辑
// 修改类名为 Kernel<YourOp>
class KernelAdd {
public:
    __aicore__ inline KernelAdd(AscendC::TPipe* pipe)
    {
        pipe_ = pipe;
    };
        
    // [MODIFY] 根据你的算子修改TilingData结构体名
    // Init: 设置 Global Memory 指针和计算参数
    __aicore__ inline void Init(GM_ADDR x, GM_ADDR y, GM_ADDR z,
                                const __gm__ AddTilingData* tiling)
    {
        // 按照TILE_LENGTH计算需要循环多少次、最后一次需要处理多少数据量。
        this->tiling = tiling;
        uint32_t blockIdx = AscendC::GetBlockIdx();
        if (blockIdx < tiling->blockNum - 1) {
            total = tiling->numPerCore;
            tileNum = total / TILE_LENGTH;
            tailTileElementNum = TILE_LENGTH;
        } else {
            total = tiling->tailNumLastCore;
            tileNum = (total + (TILE_LENGTH - 1))/ TILE_LENGTH;
            tailTileElementNum = total - TILE_LENGTH * (tileNum - 1);
        }

        // [MODIFY] 根据你的输入/输出数量调整 Global Tensor
        xGm.SetGlobalBuffer((__gm__ float *)x + blockIdx * tiling->numPerCore, total);
        yGm.SetGlobalBuffer((__gm__ float *)y + blockIdx * tiling->numPerCore, total);
        zGm.SetGlobalBuffer((__gm__ float *)z + blockIdx * tiling->numPerCore, total);


        // [MODIFY] 根据你的算子计算逻辑，调整UB Buffer初始化
        // inQueueX/inQueueY/outQueueZ用于搬入/搬出
        // 开启double buffer，有利于MTE/VEC流水并行。
        pipe_->InitBuffer(inQueueX, DOUBLE_BUFFER, TILE_LENGTH * sizeof(float));
        pipe_->InitBuffer(inQueueY, DOUBLE_BUFFER, TILE_LENGTH * sizeof(float));
        pipe_->InitBuffer(outQueueZ, DOUBLE_BUFFER, TILE_LENGTH * sizeof(float));

        // [MODIFY] 根据你的算子计算逻辑，其他中间计算过程中占用的UB Buffer在这里初始化
        // 中间计算过程**不要**开启double buffer!!! 比如:
        // pipe_.InitBuffer(tmpBuf_, 1024);
    }

    // Process: 执行 CopyIn → Compute → CopyOut 流程
    __aicore__ inline void Process()
    {
        for (uint32_t i = 0; i < tileNum; i++) {
            uint32_t count = (i == tileNum - 1) ? tailTileElementNum : TILE_LENGTH;
            CopyIn(count);
            Compute(count);
            CopyOut(count);
        }
    }

    // CopyIn: 从GM将数据拷贝到UB
    __aicore__ inline void CopyIn(uint32_t count)
    {
        // [MODIFY] 根据你的输入数量调整 LocalTensor 数量和数据类型
        AscendC::LocalTensor<float> xLocal = inQueueX.AllocTensor<float>();
        AscendC::LocalTensor<float> yLocal = inQueueY.AllocTensor<float>();

        // [MODIFY] 根据你的业务场景，调整搬入参数
        // 使用DataCopyPad应对非32字节对齐场景
        // DataCopyExtParams{blockCount(uint16_t), blockLen(uint32_t,字节), srcStride, dstStride}
        // stride 单位：GM侧=字节，UB侧=dataBlock(32B)。CopyIn: srcStride=字节, dstStride=dataBlock
        AscendC::DataCopyPad(xLocal, xGm,
            {1, static_cast<uint16_t>(count * sizeof(float)), 0, 0},
            {false, 0, 0, 0});
        AscendC::DataCopyPad(yLocal, yGm,
            {1, static_cast<uint16_t>(count * sizeof(float)), 0, 0},
            {false, 0, 0, 0});

        // 搬入之后，调用EnQue，使用前调用DeQue
        inQueueX.EnQue(xLocal);
        inQueueY.EnQue(yLocal);
    }

    // CopyOut: 将计算结果从UB拷贝到GM
    __aicore__ inline void CopyOut(uint32_t count)
    {
        // [MODIFY] 根据你的输出数量调整 LocalTensor 数量和数据类型
        // 搬出前调用DeQue, 保证数据已完成计算写入 LocalTensor
        AscendC::LocalTensor<float> zLocal = outQueueZ.DeQue<float>();

        // [MODIFY] 根据你的业务场景，调整搬出参数
        // 使用DataCopyPad应对非32字节对齐场景
        // CopyOut: srcStride=dataBlock(32B), dstStride=字节（与CopyIn相反）
        AscendC::DataCopyPad(zGm, zLocal,
            {1, static_cast<uint16_t>(count * sizeof(float)), 0, 0});

        // 搬完后，记得FreeTensor.
        outQueueZ.FreeTensor(zLocal);
    }

    // Compute: 算子核心计算过程
    __aicore__ inline void Compute(uint32_t count)
    {
        // [MODIFY] 根据你的计算逻辑，调整 LocalTensor 数量和类型
        // [PATTERN] 使用前调用 DeQue 确保GM搬入已完成
        AscendC::LocalTensor<float> xLocal = inQueueX.DeQue<float>();
        AscendC::LocalTensor<float> yLocal = inQueueY.DeQue<float>();

        // 调用AllocTensor分配UB，存放计算结果，后续搬出到GM
        AscendC::LocalTensor<float> zLocal = outQueueZ.AllocTensor<float>();

        // [MODIFY] 根据你的计算逻辑，计算过程中会用到其他UB空间 LocalTensor 存放中间计算结果，调用Get接口，比如：
        // AscendC::LocalTensor<float> reduceTmpLocal = tmpBuf_.Get<float>();

        // [MODIFY] 替换为你的计算逻辑
        AscendC::Add(zLocal, xLocal, yLocal, count);

        // [PATTERN] 计算结束后，需要搬出到GM的UB，**必须**调用 EnQue
        outQueueZ.EnQue<float>(zLocal);

        // [PATTERN] 其他的通过AllocTensor分配及DeQue获取的Tensor，**必须**使用FreeTensor释放。
        inQueueX.FreeTensor(xLocal);
        inQueueY.FreeTensor(yLocal);
    }

private:
    AscendC::TPipe* pipe_;
    // [MODIFY] 修改TilingData结构体名
    const __gm__ AddTilingData* tiling;

    // [MODIFY] 根据你的输入/输出数量调整
    AscendC::GlobalTensor<float> xGm;
    AscendC::GlobalTensor<float> yGm;
    AscendC::GlobalTensor<float> zGm;

    // [MODIFY] 根据你的输入/输出数量调整, UB空间用于存放搬入数据和计算结果
    AscendC::TQue<AscendC::TPosition::VECIN, 1> inQueueX, inQueueY;
    AscendC::TQue<AscendC::TPosition::VECOUT, 1> outQueueZ;

    // [MODIFY] 根据你的算子计算逻辑，其他中间计算过程中占用的UB 在这里初始化，如：
    // AscendC::TBuf<AscendC::TPosition::VECCALC> tmpBuf_;

    uint32_t total; // 当前核总共处理元素数量
    uint32_t tileNum; // 按照TILE_LENGTH切分后，循环计算次数
    uint32_t tailTileElementNum; // element number of last tail.
};

// [MODIFY] 核函数入口 - 修改函数名 add_custom → <your_op>_custom, 参数列表根据你的算子调整
// [MODIFY] 向量算子使用 __vector__，矩阵、混合算子使用 __aicore__
extern "C" __global__ __vector__ void add_custom(GM_ADDR x, GM_ADDR y, GM_ADDR z, GM_ADDR tiling)
{
    AscendC::TPipe pipe;
    KernelAdd op(&pipe);  // [MODIFY] 修改类名
    op.Init(x, y, z, (__gm__ AddTilingData*)tiling);
    op.Process();
}

// ============================================================================
// Host 端代码 - 运行在 CPU 上
// ============================================================================

struct ArgInfo {
    std::string fileName;
    size_t length;
};

// [PATTERN] KernelCall 封装 - 处理完整的核函数调用流程
void KernelCall(uint32_t blockNum, aclrtStream stream,
    std::vector<ArgInfo> &inputsInfo, std::vector<ArgInfo> &outputsInfo, 
    uint8_t *tilingData)
{
    std::vector<uint8_t *> inputHost(inputsInfo.size());
    std::vector<uint8_t *> inputDevice(inputsInfo.size());
    std::vector<uint8_t *> outputHost(outputsInfo.size());
    std::vector<uint8_t *> outputDevice(outputsInfo.size());
    uint8_t *tilingDevice = nullptr;

    // 1. 分配并拷贝 Tiling 数据到 Device
    aclrtMalloc((void **)&tilingDevice, sizeof(AddTilingData), ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMemcpy(tilingDevice, sizeof(AddTilingData), tilingData, 
        sizeof(AddTilingData), ACL_MEMCPY_HOST_TO_DEVICE);

    // 2. 处理输入: Host → Device
    for (size_t i = 0; i < inputsInfo.size(); i++) {
        aclrtMallocHost((void **)&inputHost[i], inputsInfo[i].length);
        aclrtMalloc((void **)&inputDevice[i], inputsInfo[i].length, ACL_MEM_MALLOC_HUGE_FIRST);
        ReadFile(inputsInfo[i].fileName, inputsInfo[i].length, inputHost[i], inputsInfo[i].length);
        aclrtMemcpy(inputDevice[i], inputsInfo[i].length, inputHost[i],
            inputsInfo[i].length, ACL_MEMCPY_HOST_TO_DEVICE);
    }

    // 3. 分配输出内存
    for (size_t i = 0; i < outputsInfo.size(); i++) {
        aclrtMallocHost((void **)&outputHost[i], outputsInfo[i].length);
        aclrtMalloc((void **)&outputDevice[i], outputsInfo[i].length, ACL_MEM_MALLOC_HUGE_FIRST);
    }

    // 4. 调用核函数 <<<>>> 语法
    // [MODIFY] 修改函数名和参数
    add_custom<<<blockNum, nullptr, stream>>>(
        inputDevice[0], inputDevice[1],
        outputDevice[0], tilingDevice);
    aclrtSynchronizeStream(stream);

    // 5. 拷贝输出: Device → Host，并释放内存
    aclrtFree(tilingDevice);
    for (size_t i = 0; i < outputsInfo.size(); i++) {
        aclrtMemcpy(outputHost[i], outputsInfo[i].length, outputDevice[i], 
            outputsInfo[i].length, ACL_MEMCPY_DEVICE_TO_HOST);
        WriteFile(outputsInfo[i].fileName, outputHost[i], outputsInfo[i].length);
        aclrtFree(outputDevice[i]);
        aclrtFreeHost(outputHost[i]);
    }

    for (size_t i = 0; i < inputsInfo.size(); i++) {
        aclrtFree(inputDevice[i]);
        aclrtFreeHost(inputHost[i]);
    }
}

// [PATTERN] ACL 标准初始化流程
int32_t main(int32_t argc, char *argv[])
{
    // ACL 初始化（固定流程，无需修改）
    aclInit(nullptr);
    int32_t deviceId = 0;
    auto ret = aclrtSetDevice(deviceId);
    if (ret != ACL_SUCCESS) {
        printf("aclrtSetDevice failed, ret=%d\n", ret);
        return ret;
    }

    // [MODIFY] 获取设备最大核数（必须在 aclrtSetDevice 之后）
    // 纯向量算子示例
    // 矩阵算子使用：ACL_DEV_ATTR_CUBE_CORE_NUM
    // 混合算子使用：ACL_DEV_ATTR_AICORE_CORE_NUM
    int64_t availableCoreNum = 0;
    ret = aclrtGetDeviceInfo(deviceId, ACL_DEV_ATTR_VECTOR_CORE_NUM, &availableCoreNum);
    if (ret != ACL_SUCCESS) {
        printf("aclrtGetDeviceInfo failed, ret=%d\n", ret);
        aclrtResetDevice(deviceId);
        return ret;
    }

    // [MODIFY] 根据你的算子调整这些参数
    uint32_t totalLength = 4096 * 8;                // 总数据量
    size_t inputByteSize = totalLength * sizeof(float);
    size_t outputByteSize = totalLength * sizeof(float);

    // [MODIFY] 设置 Tiling 数据，动态计算实际使用核数blockNum
    AddTilingData tiling;
    tiling.totalLength = totalLength;
    uint64_t totalTiles = (totalLength + TILE_LENGTH - 1) / TILE_LENGTH;
    uint64_t tilesPerCore = (totalTiles + availableCoreNum - 1) / availableCoreNum;
    uint32_t blockNum = tiling.blockNum = (totalTiles + tilesPerCore - 1) / tilesPerCore;
    tiling.numPerCore = tilesPerCore * TILE_LENGTH;
    tiling.tailNumLastCore = totalLength - tiling.numPerCore * (blockNum - 1);

    // [MODIFY] 根据你的输入/输出文件调整
    std::vector<ArgInfo> inputsInfo = {
        {"./input/input_x.bin", inputByteSize},
        {"./input/input_y.bin", inputByteSize}
    };
    std::vector<ArgInfo> outputsInfo = {
        {"./output/output.bin", outputByteSize}
    };

    // ACL 初始化（固定流程，无需修改）	
    aclrtStream stream = nullptr;
    aclrtCreateStream(&stream);

    KernelCall(blockNum, stream, inputsInfo, outputsInfo, (uint8_t *)&tiling);
    
    // ACL 清理（固定流程）
    aclrtDestroyStream(stream);
    aclrtResetDevice(deviceId);
    aclFinalize();

    return 0;
}
