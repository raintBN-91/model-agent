{
  "name": "semnasnet-npu",
  "description": "SEMNASNet (semnasnet_100 / semnasnet_075) 图像分类模型在昇腾 NPU 上的部署、推理、精度测试、文档生成和模型仓库发布一站式工具",
  "version": "1.0.0",
  "type": "deployment",
  "models": [
    "timm/semnasnet_100.rmsp_in1k",
    "timm/semnasnet_075.rmsp_in1k"
  ],
  "tags": ["NPU", "Ascend", "CV", "image-classification", "timm", "PyTorch"],
  "hardware": ["Ascend910"],
  "framework": ["PyTorch", "timm"],
  "repository": {
    "fork": "https://gitcode.com/m0_74196153/model-agent",
    "upstream": "https://gitcode.com/Ascend/model-agent",
    "branch": "feature/semnasnet-npu-skill"
  },
  "inputs": {
    "model_name": {
      "type": "string",
      "description": "模型名称：semnasnet_100.rmsp_in1k 或 semnasnet_075.rmsp_in1k",
      "required": true
    },
    "device": {
      "type": "string",
      "description": "推理设备：cpu 或 npu",
      "default": "npu",
      "enum": ["cpu", "npu"]
    },
    "image_path": {
      "type": "string",
      "description": "输入图像路径（可选，默认使用合成测试图像）",
      "required": false
    }
  },
  "outputs": {
    "inference_results": "推理结果（Top-5 预测类别和概率）",
    "accuracy_metrics": "CPU/NPU 精度对比指标",
    "terminal_screenshot": "模拟终端输出截图"
  }
}
