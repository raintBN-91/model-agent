{
  "name": "single_batch_latency",
  "description": "单 batch 延迟基线测试，衡量最小并发下的端到端推理延迟",
  "applicable_versions": [
    "0.4.x",
    "0.5.x",
    "0.6.x"
  ],
  "parameters": {
    "model": "${MODEL_PATH}",
    "input_len": 128,
    "output_len": 128,
    "batch_size": 1,
    "tensor_parallel_size": "${TP_SIZE:-1}",
    "device": "npu"
  },
  "version_specific_args": {
    "0.4.x": {
      "script": "python -m vllm.benchmarks.benchmark_latency",
      "extra_args": []
    },
    "0.5.x": {
      "script": "vllm bench latency",
      "extra_args": ["--num-iters", "3"]
    },
    "0.6.x": {
      "script": "vllm bench latency",
      "extra_args": ["--num-iters", "3"]
    }
  },
  "metrics": [
    "mean_latency_ms",
    "p50_latency_ms",
    "p99_latency_ms",
    "token_throughput"
  ],
  "expected_duration": "1-3 minutes"
}
